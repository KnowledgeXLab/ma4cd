# ============================================================================
# LLM 网关（OpenAI 兼容中转）— 必填
# ============================================================================
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# 兼容写法（与 OPENAI_* 二选一或同时设置）
MA4CD_LLM_API_KEY=your-api-key-here
MA4CD_LLM_BASE_URL=https://your-openai-compatible-endpoint/v1

# 全链路模型（默认 deepseek-chat，需与网关支持的模型名一致）
MA4CD_DEFAULT_MODEL=deepseek-chat
MA4CD_COMMANDER_MODEL=deepseek-chat
MA4CD_SCOUT_MODEL=deepseek-chat
MA4CD_MINER_SMALL_MODEL=deepseek-chat
MA4CD_MINER_BIG_MODEL=deepseek-chat
MA4CD_INSPECTOR_MODEL=deepseek-chat
MA4CD_CURATOR_MODEL=deepseek-chat

# 直连 OpenAI 官方 API 时，deepseek-* 会自动回退到 gpt-4o-mini
# MA4CD_OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ============================================================================
# 搜索 / 爬取 API
# ============================================================================
TAVILY_API_KEY=your-tavily-key
SCRAPINGDOG_API_KEY=your-scrapingdog-key
# 与 SCRAPINGDOG_API_KEY 等价（Scout 会读任一变量）
MA4CD_SCOUT_BACKUP_SEARCH_API_KEY=your-scrapingdog-key
# Tavily 超额时优先 ScrapingDog
MA4CD_SCOUT_PROVIDER_ORDER=backup_search,tavily,ddg

# ============================================================================
# Scout 配置（可选）
# ============================================================================
MA4CD_USE_ENHANCED_SCOUT=0
MA4CD_SCOUT_RESULTS_PER_QUERY=20
MA4CD_SCOUT_MIN_SEED_URLS=50
MA4CD_SCOUT_MAX_ITERATIONS=3
MA4CD_SCOUT_ENABLE_URL_EXPANSION=1
MA4CD_SCOUT_URL_EXPANSION_MAX_LINKS=5
MA4CD_SCOUT_URL_EXPANSION_TIMEOUT=10

# ============================================================================
# Miner / Inspector 并发与超时（可选）
# ============================================================================
MA4CD_MINER_CONCURRENCY=3
MA4CD_MINER_URL_TIMEOUT=600
MA4CD_MINER_MIN_SEED_URLS=50
MA4CD_MINER_MAX_SEED_URLS=120
MA4CD_INSPECTOR_MAX_WORKERS=6
MA4CD_INSPECTOR_BATCH_SIZE=6
MA4CD_INSPECTOR_LLM_RETRIES=4
MA4CD_REPORT_TIMEOUT=180

# ============================================================================
# 记忆 / Chroma（可选）
# ============================================================================
# MA4CD_DISABLE_CHROMA_MEMORY=0
# MA4CD_REUSE_ACTIVE_SESSION=0

# ============================================================================
# Redis 记忆后端（可选，MA4CD_MEMORY_BACKEND=redis 时启用）
# ============================================================================
# MA4CD_MEMORY_BACKEND=file
# MA4CD_REDIS_URL=redis://localhost:6379/0
# MA4CD_REDIS_KEY_PREFIX=ma4cd
# MA4CD_REDIS_ENV=dev
# MA4CD_WORKING_TTL=7200
# MA4CD_SESSION_ARCHIVE_TTL=604800
# MA4CD_SESSION_MAX_EVENTS=5000
# MA4CD_INSPECTOR_REPORT_TTL=0
# MA4CD_REDIS_AUX=1
# MA4CD_REDIS_CACHE_TTL=300
# MA4CD_SCOUT_SEARCH_CACHE_TTL=86400
# MA4CD_BATCH_CHECKPOINT_BACKEND=redis
# MA4CD_PIPELINE_CHECKPOINT=1
# MA4CD_PIPELINE_CHECKPOINT_BACKEND=redis
# MA4CD_PIPELINE_CHECKPOINT_TTL=604800
# MA4CD_PIPELINE_FORCE_FRESH=0
# MA4CD_SESSION_COLLAB=1
# MA4CD_SESSION_EVENTS_MAXLEN=2000
# MA4CD_CURATOR_SCOUT_LOOP=0
# MA4CD_CURATOR_SCOUT_MAX_URLS=5

# ============================================================================
# 领域 Skill（可选 — 外置 Inspector/Miner 规则包）
# ============================================================================
# MA4CD_SKILL=protein-research
# 或: python main_workflow.py --skill protein-research "寻找蛋白质研究数据"
# Skill 可覆盖 Miner 进化闸门（env 优先）: MA4CD_EVOLVE_MIN_RECALL_SCORE, MA4CD_POSITIVE_EVOLVE_MIN_ASSETS 等
